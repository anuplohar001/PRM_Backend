generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ResourceType {
  ORGANIZATION
  PROJECT
  TEAM
}

enum TargetType {
  USER
}

enum EffectType {
  ALLOW
  DECLINE
}

enum Action {
  // Define your actions here, for example:
  ORG_OWNER_ACTIONS
  ORG_ADMIN_ACTIONS
  PROJECT_ADMIN_ACTIONS
  PROJECT_MEMBER_ACTIONS
  TEAM_ADMIN_ACTIONS
  TEAM_MEMBER_ACTIONS
}

enum OrgRoles {
  ORG_ADMIN
  ORG_OWNER
  ORG_MEMBER
}

enum ProjectRoles {
  PROJECT_ADMIN
  PROJECT_MEMBER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum TeamRoles {
  TEAM_ADMIN
  TEAM_MEMBER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum TaskType {
  BUG
  FEATURE
  TASK
  IMPROVEMENT
  STORY
  SUBTASK
  EPIC
}

enum ActionType {
  CREATE_USER
  DELETE_USER

  CREATE_TEAM
  DELETE_TEAM

  CREATE_TASK
  ASSIGN_TASK
  UPDATE_TASK
  DELETE_TASK

  CREATE_WORKFLOW
}
enum EntityType {
  USER
  TASK
  PROJECT
  TEAM
  WORKFLOW
  COMMENT
}

enum VisibilityType {
  PRIVATE
  PROJECT
  CUSTOM
}

model Log {
  endpoint  String?
  method    String?
  metadata  Json?
  createdAt DateTime @default(now())
  userId    Int?
  id        Int      @id @default(autoincrement())
}

model Users {
  id                      Int                   @id @default(autoincrement())
  name                    String
  email                   String                @unique
  description             String?
  password                String
  role                    String
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  createdById             Int?
  updatedById             Int?
  createdBy               Users?                @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers            Users[]               @relation("UserCreatedBy")
  updatedBy               Users?                @relation("UserUpdatedBy", fields: [updatedById], references: [id])
  updatedUsers            Users[]               @relation("UserUpdatedBy")
  organizationMemberships OrganizationMembers[]
  createdOrganizations    Organizations[]       @relation("UserCreatedBy")
  updatedOrganizations    Organizations[]       @relation("UserUpdatedBy")
  projectMemberships      ProjectMembers[]
  createdProjects         Projects[]            @relation("UserCreatedBy")
  updatedProjects         Projects[]            @relation("UserUpdatedBy")

  orgMemberAddedBy  OrganizationMembers[] @relation("OrgMemberAddedBy")
  projMemberAddedBy ProjectMembers[]      @relation("ProjectMemberAddedBy")

  policies Policy[] @relation("ResourcePolicies")

  createdTeams Team[] @relation("TeamCreatedBy")
  updatedTeams Team[] @relation("TeamUpdatedBy")

  addedTeamMembers TeamMember[] @relation("TeamMemberAddedBy") //users added by TEAM_ADMIN
  teamMemberships  TeamMember[] //all teams where this user is member of that teams

  assignedTasks     Task[] @relation("AssignedTo")
  tasksAssignedByMe Task[] @relation("AssignedBy")

  activities           Activity[]
  activityVisibilities ActivityVisibility[]
}

model Policy {
  id         Int          @id @default(autoincrement())
  resourceId Int
  resource   ResourceType

  target   TargetType
  targetId Int

  effect      EffectType
  permissions Action[]

  user Users @relation("ResourcePolicies", fields: [targetId], references: [id])

  @@unique([resourceId, targetId, resource])
  @@map("policies")
}

model Organizations {
  id             Int                   @id @default(autoincrement())
  name           String
  description    String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  createdById    Int?
  updatedById    Int?
  members        OrganizationMembers[]
  createdBy      Users?                @relation("UserCreatedBy", fields: [createdById], references: [id])
  updatedBy      Users?                @relation("UserUpdatedBy", fields: [updatedById], references: [id])
  projects       Projects[]
  projectMembers ProjectMembers[]
  teams          Team[]

  @@map("organizations")
}

model OrganizationMembers {
  id             Int      @id @default(autoincrement())
  organizationId Int
  userId         Int
  role           OrgRoles?
  joinedAt       DateTime @default(now())
  addedById      Int?

  addedBy      Users?        @relation("OrgMemberAddedBy", fields: [addedById], references: [id])
  organization Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         Users         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model Projects {
  id             Int              @id @default(autoincrement())
  organizationId Int
  name           String
  description    String?
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  createdById    Int?
  updatedById    Int?
  status         ProjectStatus    @default(PLANNING)
  workflow       WorkFlow[]
  members        ProjectMembers[]
  createdBy      Users?           @relation("UserCreatedBy", fields: [createdById], references: [id])
  organization   Organizations    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedBy      Users?           @relation("UserUpdatedBy", fields: [updatedById], references: [id])
  teams          Team[]

  tasks      Task[]
  activities Activity[]

  @@map("projects")
}

model ProjectMembers {
  id             Int      @id @default(autoincrement())
  projectId      Int
  organizationId Int?
  userId         Int
  joinedAt       DateTime @default(now())
  addedById      Int?

  addedBy      Users?         @relation("ProjectMemberAddedBy", fields: [addedById], references: [id])
  role         ProjectRoles   @default(PROJECT_MEMBER)
  project      Projects       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organizations? @relation(fields: [organizationId], references: [id])
  user         Users          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Team {
  id   Int    @id @default(autoincrement())
  name String

  // Foreign Keys
  organizationId Int
  projectId      Int?

  // Relations
  organization Organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Projects?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Optional: team members
  members TeamMember[]

  createdById Int
  updatedById Int

  createdBy Users @relation("TeamCreatedBy", fields: [createdById], references: [id])
  updatedBy Users @relation("TeamUpdatedBy", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([projectId])
}

model TeamMember {
  id Int @id @default(autoincrement())

  teamId    Int
  userId    Int
  role      TeamRoles @default(TEAM_MEMBER)
  addedById Int?

  addedBy Users? @relation("TeamMemberAddedBy", fields: [addedById], references: [id])
  member  Users  @relation(fields: [userId], references: [id])
  team    Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model WorkFlow {
  id          Int      @id @default(autoincrement())
  projectId   Int
  name        String
  description String
  position    Int
  createdAt   DateTime @default(now())
  project     Projects @relation(fields: [projectId], references: [id])

  task Task[]

  @@unique([projectId, name])
  @@unique([projectId, position])
}

model Task {
  id Int @id @default(autoincrement())

  title       String
  description String?

  priority Priority?
  type     TaskType?

  projectId Int
  project   Projects @relation(fields: [projectId], references: [id], onDelete: Cascade)

  statusId Int?
  status   WorkFlow? @relation(fields: [statusId], references: [id], onDelete: SetNull)

  assignedBy     Int?
  assignedByUser Users? @relation("AssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  assignedTo     Int?
  assignedToUser Users? @relation("AssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([statusId])
}

model Activity {
  id Int @id @default(autoincrement())

  actorId Int
  actor   Users @relation(fields: [actorId], references: [id], onDelete: Cascade)

  action ActionType
  module String

  entityId   Int?
  entityType  EntityType?

  projectId Int?
  project   Projects? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Visibility
  visibilityType  VisibilityType
  visibilityUsers ActivityVisibility[]

  metadata Json?

  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([projectId, createdAt])
}

model ActivityVisibility {
  id Int @id @default(autoincrement())

  activityId Int
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  userId Int
  user   Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([userId])
}
